# Set default behavior to automatically normalize line endings.
* text=auto

# Force batch scripts to always use CRLF line endings on checkout.
*.bat text eol=crlf

# Force bash scripts to always use LF line endings on checkout.
*.sh text eol=lf

# Unity YAML-based text assets — merge with Unity smart merge driver
*.cs diff=csharp
*.anim merge=unityyamlmerge eol=lf
*.asset merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.cubemap merge=unityyamlmerge eol=lf
*.flare merge=unityyamlmerge eol=lf
*.fontsettings merge=unityyamlmerge eol=lf
*.guiskin merge=unityyamlmerge eol=lf
